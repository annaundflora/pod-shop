{
    "name": "pod-shop/spreadconnect-pod",
    "description": "Spreadconnect POD WordPress Plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SpreadconnectPod\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/slices/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
