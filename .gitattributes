# Normalize line endings to LF in repository
* text=auto eol=lf

# Force LF for shell scripts (important for Docker/Linux execution)
*.sh text eol=lf
*.php text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# Pipeline-generated files (collapsed in GitHub PR diffs)
specs/**          linguist-generated=true
