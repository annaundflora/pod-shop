NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql
NEXT_PUBLIC_WP_URL=http://localhost:8080
NEXT_PUBLIC_WC_CHECKOUT_URL=http://localhost:8080/checkout
# Pinterest Tag ID (aus Pinterest Ads Manager → Conversions → Tag erstellen)
NEXT_PUBLIC_PINTEREST_TAG_ID=your_pinterest_tag_id_here
# Shop-Name (wird in Metadata-Titeln und Header-Logo verwendet)
NEXT_PUBLIC_SHOP_NAME=POD Shop

# Theme Selection
# Selects the theme folder from frontend/themes/{NEXT_PUBLIC_THEME}/
# Available themes: default, zweiter-shop, kleinstadtpflanze
NEXT_PUBLIC_THEME=default
